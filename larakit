# Scan an array of args for flags; exports DRY_RUN, LARAKIT_QUIET, LARAKIT_FORCE
parse_flags() {
  local -n _ref=$1
  shift
  local filtered=()
  local skip_next=false
  for arg in "${_ref[@]+"${_ref[@]}"}"; do
    if [[ "$skip_next" == "true" ]]; then
      skip_next=false
      continue
    fi
    case "$arg" in
      --dry-run | -n) export DRY_RUN=true ;;
      --quiet | -q) export LARAKIT_QUIET=true ;;
      --force | -f) export LARAKIT_FORCE=true ;;
      --profile=*)
        export LARAKIT_PROFILE="${arg#--profile=}"
        filtered+=("$arg")
        ;;
      --profile)
        export LARAKIT_PROFILE="${_ref[*]+${_ref[1]:-}}"
        filtered+=("$arg")
        ;;
      --app=*) export LARAKIT_APP="${arg#--app=}" ;;
      --app)
        export LARAKIT_APP="${_ref[*]+${_ref[1]:-}}"
        skip_next=true
        ;;
      *) filtered+=("$arg") ;;
    esac
  done
  _ref=("${filtered[@]+"${filtered[@]}"}")
}

has_flag() {
  local flag="$1"
  shift
  for arg in "$@"; do
    [[ "$arg" == "$flag" || "$arg" == "-h" && "$flag" == "--help" ]] && return 0
  done
  return 1
}

# Auto-detect app from current working directory.
# Priority: 1) .larakit project file (walk up from $PWD)
#           2) APP_PATH match in ~/.larakit-creds.* (longest match wins)
# Only runs if --app was not given.
auto_detect_app() {
  [[ -n "${LARAKIT_APP:-}" ]] && return

  # 1. Walk up from $PWD looking for a .larakit file
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    if [[ -f "${dir}/.larakit" ]]; then
      local file_app
      file_app=$(grep "^APP=" "${dir}/.larakit" 2> /dev/null | cut -d'=' -f2- | head -1 | tr -d ' ')
      if [[ -n "$file_app" ]]; then
        export LARAKIT_APP="$file_app"
        dim "Auto-detected app: ${LARAKIT_APP}  (${dir}/.larakit)"
        return
      fi
    fi
    dir="$(dirname "$dir")"
  done

  # 2. Scan ~/.larakit-creds.* for APP_PATH matching $PWD
  local cwd="$PWD"
  local best_app="" best_len=0

  shopt -s nullglob
  for f in "$HOME"/.larakit-creds.*; do
    local app="${f##*\.larakit-creds\.}"
    local app_path
    app_path=$(grep "^APP_PATH=" "$f" 2> /dev/null | cut -d'=' -f2- | head -1)
    if [[ -n "$app_path" && "$cwd" == "$app_path"* && "${#app_path}" -gt "$best_len" ]]; then
      best_app="$app"
      best_len="${#app_path}"
    fi
  done
  shopt -u nullglob

  if [[ -n "$best_app" ]]; then
    export LARAKIT_APP="$best_app"
    dim "Auto-detected app: ${LARAKIT_APP}  (${PWD})"
  fi
}

# Call after parse_flags — re-points CREDS_FILE to the app-specific file.
resolve_creds_file() {
  auto_detect_app
  if [[ -n "${LARAKIT_APP:-}" ]]; then
    export CREDS_FILE="${HOME}/.larakit-creds.${LARAKIT_APP}"
  fi
}

CMD="${1:-help}"
shift || true

# larakit --help / larakit -h with no command
[[ "$CMD" == "--help" || "$CMD" == "-h" ]] && CMD="help"

case "$CMD" in
  init)
    ARGS=("$@")
    has_flag --help "${ARGS[@]+"${ARGS[@]}"}" && {
      manage_help "init"
      exit 0
    }
    parse_flags ARGS
    resolve_creds_file
    require_root
    run_manage "init"
    ;;
  diagnose | diag)
    ARGS=("$@")
    has_flag --help "${ARGS[@]+"${ARGS[@]}"}" && {
      manage_help "diagnose"
      exit 0
    }
    parse_flags ARGS
    resolve_creds_file
    require_root
    run_manage "diagnose"
    ;;
  setup)
    ARGS=("$@")
    has_flag --help "${ARGS[@]+"${ARGS[@]}"}" && {
      cmd_setup_help
      exit 0
    }
    parse_flags ARGS
    resolve_creds_file
    require_root
    bash "${LARAKIT_HOME}/setup.sh" "${ARGS[@]+"${ARGS[@]}"}"
    ;;
  install | i)
    ARG="${1:-}"
    [[ "$ARG" == "--help" || "$ARG" == "-h" || -z "$ARG" ]] && {
      cmd_list_modules
      exit 0
    }
    shift || true
    ARGS=("$@")
    has_flag --help "${ARGS[@]+"${ARGS[@]}"}" && {
      module_help "$ARG"
      exit 0
    }
    parse_flags ARGS
    resolve_creds_file
    require_root
    run_module "$ARG"
    ;;
  manage | m | run)
    ARG="${1:-}"
    [[ "$ARG" == "--help" || "$ARG" == "-h" || -z "$ARG" ]] && {
      cmd_list_manage
      exit 0
    }
    shift || true
    ARGS=("$@")
    has_flag --help "${ARGS[@]+"${ARGS[@]}"}" && {
      manage_help "$ARG"
      exit 0
    }
    parse_flags ARGS
    resolve_creds_file
    require_root
    run_manage "$ARG"
    ;;
  list | ls)
    FILTER="${1:-all}"
    case "$FILTER" in
      modules | install) cmd_list_modules ;;
      manage | run) cmd_list_manage ;;
      *)
        cmd_list_modules
        cmd_list_manage
        ;;
    esac
    ;;
  update)
    ARGS=("$@")
    parse_flags ARGS
    resolve_creds_file
    require_root
    run_manage "self-update"
    ;;
  status)
    ARGS=("$@")
    parse_flags ARGS
    resolve_creds_file
    require_root
    run_manage "health"
    ;;
  apps)
    section "Configured Apps"
    shopt -s nullglob
    found=false
    for f in "$HOME"/.larakit-creds.*; do
      app="${f##*.larakit-creds.}"
      domain=$(grep "^APP_DOMAIN=" "$f" 2> /dev/null | cut -d'=' -f2- || echo "—")
      printf "  ${BOLD}%-20s${NC} %s  ${DIM}%s${NC}\n" "$app" "$domain" "$f"
      found=true
    done
    if [[ -f "$HOME/.larakit-creds" ]]; then
      domain=$(grep "^APP_DOMAIN=" "$HOME/.larakit-creds" 2> /dev/null | cut -d'=' -f2- || echo "—")
      printf "  ${BOLD}%-20s${NC} %s  ${DIM}%s${NC}\n" "(default)" "$domain" "$HOME/.larakit-creds"
      found=true
    fi
    [[ "$found" == "false" ]] && info "No apps configured yet. Run: larakit setup"
    echo -e "\n  ${DIM}Use --app <name> with any command to target a specific app.${NC}\n"
    ;;
  version | -v | --version)
    echo "larakit v${LARAKIT_VERSION} — home: ${LARAKIT_HOME}"
    # Non-blocking update check via GitHub API
    if has_cmd curl; then
      latest=""
      latest=$(curl -fsSL --max-time 3 \
        "https://api.github.com/repos/${GITHUB_USER}/${GITHUB_REPO}/releases/latest" \
        2> /dev/null | grep '"tag_name"' | cut -d'"' -f4 | tr -d 'v') || true
      if [[ -n "$latest" && "$latest" != "$LARAKIT_VERSION" ]]; then
        echo
        echo -e "  ${YELLOW}${BOLD}Update available:${NC} v${latest}  ${DIM}(you have v${LARAKIT_VERSION})${NC}"
        echo -e "  ${DIM}Run: larakit update${NC}"
      fi
    fi
    ;;
  help | --help | -h | "")
    cmd_help
    ;;
  *)
    error "Unknown command: '${CMD}'"
    echo -e "  Run ${BOLD}larakit help${NC} for usage."
    exit 1
    ;;
esac
