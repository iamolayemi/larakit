module_help() {
  local name="$1"
  local file
  file=$(resolve_module "$name")
  if [[ -z "$file" ]]; then
    error "Unknown module: '${name}'"
    cmd_list_modules
    exit 1
  fi

  local key="${file#??-}" # strip leading "00-"
  key="${key%.sh}"        # strip ".sh"
  # find canonical key in MODULE_META
  local meta=""
  for k in "${!MODULE_META[@]}"; do
    local aliases
    aliases=$(echo "${MODULE_META[$k]}" | cut -d'|' -f2-3)
    if [[ "$k" == "$name" ]] || echo "$aliases" | grep -qw "$name" 2> /dev/null; then
      meta="${MODULE_META[$k]}"
      key="$k"
      break
    fi
  done
  [[ -z "$meta" ]] && meta="${MODULE_META[$key]:-}"

  local num desc details canonical raw_aliases
  num=$(echo "$meta" | cut -d'|' -f1)
  canonical=$(echo "$meta" | cut -d'|' -f2)
  raw_aliases=$(echo "$meta" | cut -d'|' -f3)
  desc=$(echo "$meta" | cut -d'|' -f4)
  details=$(echo "$meta" | cut -d'|' -f5)

  echo -e "\n  ${BOLD}${CYAN}larakit install ${canonical}${NC}   ${DIM}(module ${num})${NC}"
  echo
  divider
  echo -e "\n  ${BOLD}Description${NC}"
  echo -e "    ${desc}\n"
  echo -e "  ${BOLD}Details${NC}"
  # word-wrap at ~70 chars
  echo "$details" | fold -s -w 70 | sed 's/^/    /'
  echo
  if [[ -n "$raw_aliases" ]]; then
    echo -e "  ${BOLD}Aliases${NC}"
    echo -e "    ${DIM}$(echo "$raw_aliases" | tr ' ' ', ')${NC}"
    echo
  fi
  echo -e "  ${BOLD}Run${NC}"
  echo -e "    ${DIM}sudo larakit install ${canonical}${NC}"
  echo
}

manage_help() {
  local name="$1"
  local file
  file=$(resolve_manage "$name")
  if [[ -z "$file" ]]; then
    error "Unknown manage command: '${name}'"
    cmd_list_manage
    exit 1
  fi

  local meta=""
  for k in "${!MANAGE_META[@]}"; do
    if [[ "$k" == "$name" ]] || echo "${MANAGE_META[$k]}" | cut -d'|' -f2 | grep -qw "$name" 2> /dev/null; then
      meta="${MANAGE_META[$k]}"
      break
    fi
  done

  local canonical raw_aliases desc details
  canonical=$(echo "$meta" | cut -d'|' -f1)
  raw_aliases=$(echo "$meta" | cut -d'|' -f2)
  desc=$(echo "$meta" | cut -d'|' -f3)
  details=$(echo "$meta" | cut -d'|' -f4)

  echo -e "\n  ${BOLD}${CYAN}larakit manage ${canonical}${NC}"
  echo
  divider
  echo -e "\n  ${BOLD}Description${NC}"
  echo -e "    ${desc}\n"
  echo -e "  ${BOLD}Details${NC}"
  echo "$details" | fold -s -w 70 | sed 's/^/    /'
  echo
  if [[ -n "$raw_aliases" ]]; then
    echo -e "  ${BOLD}Aliases${NC}"
    echo -e "    ${DIM}$(echo "$raw_aliases" | tr ' ' ', ')${NC}"
    echo
  fi
  echo -e "  ${BOLD}Run${NC}"
  echo -e "    ${DIM}sudo larakit manage ${canonical}${NC}"
  echo
}

