#!/usr/bin/env bash
# =============================================================================
#  larakit — CLI entrypoint
#  Usage: larakit <command> [args]
# =============================================================================
set -euo pipefail

LARAKIT_VERSION="1.0.0"
LARAKIT_HOME="${LARAKIT_HOME:-/opt/larakit}"

if [[ ! -d "${LARAKIT_HOME}/lib" ]]; then
  echo "ERROR: LaraKit home not found at ${LARAKIT_HOME}"
  echo "       Re-run: sudo bash install.sh"
  exit 1
fi

export SETUP_BASE_DIR="$LARAKIT_HOME"
export SETUP_LOADED=1
source "${LARAKIT_HOME}/config.sh"
source "${LARAKIT_HOME}/lib/colors.sh"
source "${LARAKIT_HOME}/lib/prompts.sh"
source "${LARAKIT_HOME}/lib/creds.sh"
source "${LARAKIT_HOME}/lib/utils.sh"

resolve_module() {
  case "${1,,}" in
    preflight | pre-flight | 0 | 00) echo "00-preflight.sh" ;;
    system | init | sysint | 1 | 01) echo "01-system-init.sh" ;;
    hardening | security | 2 | 02) echo "02-server-hardening.sh" ;;
    php | 3 | 03) echo "03-php.sh" ;;
    nginx | 4 | 04) echo "04-nginx.sh" ;;
    mysql | mariadb | db | 5 | 05) echo "05-mysql.sh" ;;
    redis | 6 | 06) echo "06-redis.sh" ;;
    node | nodejs | npm | 7 | 07) echo "07-node.sh" ;;
    ssl | tls | certbot | 8 | 08) echo "08-ssl.sh" ;;
    app | laravel | 9 | 09) echo "09-laravel-app.sh" ;;
    queue | worker | 10) echo "10-queue-worker.sh" ;;
    scheduler | cron | 11) echo "11-scheduler.sh" ;;
    horizon | 12) echo "12-horizon.sh" ;;
    reverb | websocket | ws | 13) echo "13-reverb.sh" ;;
    octane | 14) echo "14-octane.sh" ;;
    minio | s3 | 15) echo "15-minio.sh" ;;
    postgres | postgresql | pg | 16) echo "16-postgres.sh" ;;
    meilisearch | search | meili | 17) echo "17-meilisearch.sh" ;;
    typesense | ts | 18) echo "18-typesense.sh" ;;
    elasticsearch | elastic | es | 19) echo "19-elasticsearch.sh" ;;
    rabbitmq | rabbit | mq | 20) echo "20-rabbitmq.sh" ;;
    varnish | 21) echo "21-varnish.sh" ;;
    lb | loadbalancer | haproxy | 22) echo "22-load-balancer.sh" ;;
    mailpit | mail | 23) echo "23-mailpit.sh" ;;
    backups | backup | 24) echo "24-backups.sh" ;;
    tuning | tune | 25) echo "25-tuning.sh" ;;
    monitoring | monitor | 26) echo "26-monitoring.sh" ;;
    phpmyadmin | pma | 27) echo "27-phpmyadmin.sh" ;;
    pgadmin | 28) echo "28-pgadmin.sh" ;;
    soketi | pusher | 29) echo "29-soketi.sh" ;;
    memcached | memcache | 30) echo "30-memcached.sh" ;;
    chromium | chrome | pdf | wkhtml | 31) echo "31-chromium.sh" ;;
    *) echo "" ;;
  esac
}

resolve_manage() {
  case "${1,,}" in
    health | status) echo "health.sh" ;;
    report) echo "report.sh" ;;
    deploy) echo "deploy.sh" ;;
    redeploy | full-deploy) echo "redeploy.sh" ;;
    rollback) echo "rollback.sh" ;;
    restart) echo "restart.sh" ;;

    logs | log) echo "logs.sh" ;;
    backup | db-backup) echo "db-backup.sh" ;;
    restore | db-restore) echo "db-restore.sh" ;;
    ssl-renew | renew-ssl) echo "ssl-renew.sh" ;;
    queue | queue-status) echo "queue-status.sh" ;;
    test-mail | testmail) echo "test-mail.sh" ;;
    env | generate-env) echo "generate-env.sh" ;;
    webhook) echo "webhook-listen.sh" ;;
    update | self-update) echo "self-update.sh" ;;
    creds | credentials) echo "credentials.sh" ;;
    firewall | firewall-audit | fwaudit) echo "firewall-audit.sh" ;;
    init | setup-creds) echo "init.sh" ;;
    db-optimize | optimize | dbopt) echo "db-optimize.sh" ;;
    perf | performance | load-test) echo "performance-test.sh" ;;
    diagnose | diag | check) echo "diagnose.sh" ;;
    env-check | envcheck | check-env) echo "env-check.sh" ;;
    ssh-keys | sshkeys | ssh) echo "ssh-keys.sh" ;;
    swap | swapfile) echo "swap.sh" ;;
    crontab | cron-list | cronlist) echo "crontab.sh" ;;
    php-ext | phpext | extensions) echo "php-ext.sh" ;;

    db-copy | dbcopy | copy-db) echo "db-copy.sh" ;;
    logrotate | log-rotate | logs-rotate) echo "logrotate.sh" ;;
    queue-scale | scale | scale-queue) echo "queue-scale.sh" ;;
    cache-clear | cache | clear-cache) echo "cache-clear.sh" ;;
    ssl-info | ssl-status | cert-info) echo "ssl-info.sh" ;;
    app-create | new-app | create-app) echo "app-create.sh" ;;
    *) echo "" ;;
  esac
}

run_module() {
  local name="$1"
  local file
  file=$(resolve_module "$name")
  if [[ -z "$file" ]]; then
    error "Unknown module: '${name}'"
    echo -e "  Run ${BOLD}larakit list modules${NC} to see available modules."
    exit 1
  fi
  local path="${LARAKIT_HOME}/modules/${file}"
  if [[ ! -f "$path" ]]; then
    step "Downloading module: ${file}..."
    mkdir -p "${LARAKIT_HOME}/modules"
    curl -fsSL "${SETUP_BASE_URL}/modules/${file}" -o "$path"
    chmod +x "$path"
  fi
  SETUP_BASE_DIR="$LARAKIT_HOME" SETUP_LOADED=1 CREDS_FILE="$CREDS_FILE" \
    LARAKIT_APP="${LARAKIT_APP:-}" bash "$path"
}

run_manage() {
  local name="$1"
  local file
  file=$(resolve_manage "$name")
  if [[ -z "$file" ]]; then
    error "Unknown manage command: '${name}'"
    echo -e "  Run ${BOLD}larakit list manage${NC} to see available commands."
    exit 1
  fi
  local path="${LARAKIT_HOME}/manage/${file}"
  if [[ ! -f "$path" ]]; then
    step "Downloading: manage/${file}..."
    mkdir -p "${LARAKIT_HOME}/manage"
    curl -fsSL "${SETUP_BASE_URL}/manage/${file}" -o "$path"
    chmod +x "$path"
  fi
  SETUP_BASE_DIR="$LARAKIT_HOME" SETUP_LOADED=1 CREDS_FILE="$CREDS_FILE" \
    LARAKIT_APP="${LARAKIT_APP:-}" bash "$path"
}

